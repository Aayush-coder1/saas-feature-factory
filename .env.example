# ============================================================
# Band Platform Configuration
# ============================================================
# Sign up at https://app.band.ai to get your credentials
BAND_REST_URL=https://app.band.ai/
BAND_WS_URL=wss://app.band.ai/api/v1/socket/websocket
BAND_API_KEY=your-band-api-key-here
BAND_PROJECT_ID=your-project-id

# ============================================================
# Agent Credentials (created on Band platform)
# ============================================================
SPEC_AGENT_ID=your-spec-agent-uuid
SPEC_AGENT_API_KEY=your-spec-agent-api-key
CODE_GEN_AGENT_ID=your-code-gen-agent-uuid
CODE_GEN_AGENT_API_KEY=your-code-gen-agent-api-key
QA_AGENT_ID=your-qa-agent-uuid
QA_AGENT_API_KEY=your-qa-agent-api-key
DEPLOY_AGENT_ID=your-deploy-agent-uuid
DEPLOY_AGENT_API_KEY=your-deploy-agent-api-key
DOCS_AGENT_ID=your-docs-agent-uuid
DOCS_AGENT_API_KEY=your-docs-agent-api-key

# ============================================================
# LLM Provider (Groq -- 100% free inference)
# ============================================================
# Get a free API key at https://console.groq.com
OPENAI_API_BASE=https://api.groq.com/openai/v1
OPENAI_API_KEY=gsk-your-groq-api-key
MODEL_NAME=llama-3.3-70b-versatile

# ============================================================
# Local Mode (no Band account needed for demo)
# ============================================================
AGENT_MODE=local
